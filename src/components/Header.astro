---
const isHome = Astro.url.pathname === '/';
---

<header class={isHome ? 'is-home' : undefined}>
	<nav>
		<h2>
			<a href="/">
				<img src="/logo.svg" alt="Logo" class="logo" transition:name="logo" />
			</a>
		</h2>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 1rem 1.5rem 0;
		background: transparent;
		box-shadow: none;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		text-decoration: none;
		color: var(--black);
	}
	.logo {
		width: 66px;
		height: 66px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.is-home {
		padding-top: 1.75rem;
	}
	.is-home .logo {
		width: 81px;
		height: 81px;
	}
	@media (max-width: 720px) {
		header {
			padding: 0.75rem 1rem 0;
		}
		.logo {
			width: 57px;
			height: 57px;
		}
		.is-home {
			padding-top: 1.1rem;
		}
		.is-home .logo {
			width: 69px;
			height: 69px;
		}
	}
</style>
