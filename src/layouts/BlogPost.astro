---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            :global(body) {
                background: #f4efe4;
                color: #16130f;
            }
            :global(header h2 a) {
                color: #16130f;
            }
            :global(footer) {
                color: #6e665b;
            }
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }
            .prose {
                width: 900px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 2.5rem 1em 1em;
                color: #2b241d;
            }
            .title {
                margin-bottom: 1.5em;
                padding: 0.5em 0 1em;
                text-align: center;
                line-height: 1;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
            }
            .date {
                margin-bottom: 0.5em;
                color: #5f574d;
            }
            .last-updated-on {
                font-style: italic;
            }
            .prose :global(img) {
                max-width: 100%;
                width: auto;
                height: auto;
            }
            .title :global(hr) {
                border: 0;
                border-top: 1px solid rgba(110, 102, 91, 0.18);
                margin: 1.5rem 0 0;
            }
            .prose :global(a) {
                color: #6a5646;
                text-decoration-color: rgba(106, 86, 70, 0.35);
            }
            .prose :global(a:hover) {
                color: #3f342a;
                text-decoration-color: currentColor;
            }
            .prose :global(code) {
                background-color: rgba(110, 102, 91, 0.12);
            }
            @media (max-width: 720px) {
                .prose {
                    padding-top: 1.5rem;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <div class="last-updated-on">
                                        Last updated on{" "}
                                        <FormattedDate date={updatedDate} />
                                    </div>
                                )
                            }
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
